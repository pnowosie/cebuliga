---
interface Player {
  displayName: string;
  picture?: string;
  id: string;
  url: string;
  no: string | number;
  ranking: number;
}

interface Props {
  player: Player;
  groupEmoji: string;
  groupPlace: number;
  medals: Record<number, string>;
  playedMatches: number;
  totalMatches: number;
  pct: number;
  score: number;
  maxScore: number;
  groupSize: number;
}

const { player, groupEmoji, groupPlace, medals, playedMatches, totalMatches, pct, score, maxScore } = Astro.props;
---

<div class="hero">
  <div class="hero-top">
    <!-- Left: avatar + cc nick + place -->
    <div class="avatar-col">
      <div class="avatar-wrap">
        {player.picture
          ? <img src={player.picture} alt={player.displayName} width="72" height="72" />
          : <span class="avatar-fallback" />}
      </div>
      <a href={player.url} target="_blank" rel="noopener noreferrer" class="cc-link">
        {player.id}
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
      </a>
    </div>

    <!-- Middle: name + group/board + rating -->
    <div class="info-col">
      <div class="hero-name">{player.displayName}</div>
      <div class="group-row">
        <span>Grupa {groupEmoji}</span>
        <span class="board-badge">{player.no}</span>
      </div>
      <div class="rating">★ {player.ranking}</div>
    </div>

    <!-- Right: score -->
    <div class="score-col">
      <div class="score-big">{score % 1 === 0 ? score : score.toFixed(1)} pkt</div>
      {groupPlace > 0 && (
        <div class="place-badge">{medals[groupPlace] ?? ''} {groupPlace}. w grupie</div>
      )}
      <div class="score-detail">🏆 {score % 1 === 0 ? score : score.toFixed(1)} / {maxScore}</div>
    </div>
  </div>

  <div class="prog-row">
    <span class="prog-label">{playedMatches} / {totalMatches}</span>
    <div class="prog-track">
      <div class="prog-fill" style={`width:${pct}%`} />
    </div>
  </div>
</div>

<style>
  .hero {
    padding: 1.25rem 1.25rem 1.25rem 1.75rem;
    background: #161b22;
    border: 1px solid #21262d;
    border-radius: 8px;
    margin-bottom: 2rem;
  }

  .hero-top {
    display: flex;
    align-items: flex-start;
    gap: 1.75rem;
  }

  /* ── Left column: avatar + nick + place ── */
  .avatar-col {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
    flex-shrink: 0;
  }

  .avatar-wrap img,
  .avatar-fallback {
    display: block;
    width: 72px;
    height: 72px;
    border-radius: 50%;
  }

  .avatar-fallback {
    background: #21262d;
  }

  .cc-link {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    color: #484f58;
    font-size: 0.8rem;
    text-decoration: none;
  }

  .cc-link:hover {
    color: #8b949e;
  }

  .place-badge {
    font-size: 0.78rem;
    color: #c9d1d9;
    white-space: nowrap;
  }

  /* ── Middle column: name + group/board + rating ── */
  .info-col {
    flex: 0 1 auto;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .hero-name {
    font-size: 1.5rem;
    font-weight: 700;
    color: #e6edf3;
    letter-spacing: -0.02em;
    line-height: 1.2;
  }

  .group-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    color: #8b949e;
  }

  .board-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.6em;
    height: 1.6em;
    background: repeating-conic-gradient(#30363d 0% 25%, #161b22 0% 50%) 0 0 / 8px 8px;
    border-radius: 3px;
    font-weight: 700;
    font-size: 0.82rem;
    color: #e6edf3;
    border: 1px solid #21262d;
  }

  .rating {
    font-size: 0.85rem;
    color: #8b949e;
  }

  /* ── Right column: score ── */
  .score-col {
    margin-left: auto;
    flex-shrink: 0;
    text-align: right;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .score-big {
    font-size: 1.5rem;
    font-weight: 700;
    color: #e6edf3;
    line-height: 1.2;
  }

  .score-detail {
    font-size: 0.8rem;
    color: #484f58;
  }

  /* ── Progress bar: full width below ── */
  .prog-row {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-top: 1rem;
  }

  .prog-label {
    font-size: 0.75rem;
    color: #484f58;
    flex-shrink: 0;
  }

  .prog-track {
    flex: 1;
    height: 3px;
    background: #21262d;
    border-radius: 2px;
    overflow: hidden;
  }

  .prog-fill {
    height: 100%;
    background: #3fb950;
    border-radius: 2px;
  }
</style>
