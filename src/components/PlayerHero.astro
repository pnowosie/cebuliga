---
interface Player {
  displayName: string;
  picture?: string;
  id: string;
  url: string;
  no: string | number;
  ranking: number;
}

interface Props {
  player: Player;
  groupEmoji: string;
  groupPlace: number;
  medals: Record<number, string>;
  playedMatches: number;
  totalMatches: number;
  pct: number;
}

const { player, groupEmoji, groupPlace, medals, playedMatches, totalMatches, pct } = Astro.props;
---

<div class="hero">
  <div class="avatar-wrap">
    {player.picture
      ? <img src={player.picture} alt={player.displayName} width="72" height="72" />
      : <span class="avatar-fallback" />}
  </div>
  <div class="hero-info">
    <div class="hero-name">{player.displayName}</div>
    <a href={player.url} target="_blank" rel="noopener noreferrer" class="cc-link">
      {player.id}
      <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
    </a>
    <div class="hero-meta">
      <span class="board-badge">{player.no}</span>
      <span class="sep">·</span>
      <span>{groupEmoji}</span>
      {groupPlace > 0 && <>
        <span class="sep">·</span>
        <span class="place">{medals[groupPlace] ?? ''}{groupPlace}. w grupie</span>
      </>}
      <span class="sep">·</span>
      <span class="rating">★ {player.ranking}</span>
    </div>
    <div class="prog-row">
      <span class="prog-label">{playedMatches} / {totalMatches}</span>
      <div class="prog-track">
        <div class="prog-fill" style={`width:${pct}%`} />
      </div>
    </div>
  </div>
</div>

<style>
  .hero {
    display: flex;
    align-items: flex-start;
    gap: 1.25rem;
    padding: 1.25rem;
    background: #161b22;
    border: 1px solid #21262d;
    border-radius: 8px;
    margin-bottom: 2rem;
  }

  .avatar-wrap img,
  .avatar-fallback {
    display: block;
    width: 72px;
    height: 72px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .avatar-fallback {
    background: #21262d;
  }

  .hero-info {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .hero-name {
    font-size: 1.4rem;
    font-weight: 700;
    color: #e6edf3;
    letter-spacing: -0.02em;
    line-height: 1.2;
  }

  .cc-link {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    color: #484f58;
    font-size: 0.8rem;
    text-decoration: none;
  }

  .cc-link:hover {
    color: #8b949e;
  }

  .hero-meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.35rem;
    font-size: 0.85rem;
    color: #8b949e;
    margin-top: 0.1rem;
  }

  .sep {
    color: #30363d;
  }

  .board-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.6em;
    height: 1.6em;
    background: repeating-conic-gradient(#30363d 0% 25%, #161b22 0% 50%) 0 0 / 8px 8px;
    border-radius: 3px;
    font-weight: 700;
    font-size: 0.82rem;
    color: #e6edf3;
    border: 1px solid #21262d;
  }

  .place {
    color: #c9d1d9;
  }

  .rating {
    color: #8b949e;
  }

  .prog-row {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-top: 0.35rem;
  }

  .prog-label {
    font-size: 0.75rem;
    color: #484f58;
    flex-shrink: 0;
  }

  .prog-track {
    flex: 1;
    max-width: 180px;
    height: 3px;
    background: #21262d;
    border-radius: 2px;
    overflow: hidden;
  }

  .prog-fill {
    height: 100%;
    background: #3fb950;
    border-radius: 2px;
  }
</style>
