---
import Layout from '../layouts/Layout.astro';
import players from '../../data/players.json';
import tournament from '../../data/tournament.json';

const MAX_NAME = 18;
const shorten = (s: string) => s.length > MAX_NAME ? s.slice(0, MAX_NAME - 1) + '…' : s;

const groupSizes = players.reduce<Record<string, number>>((acc, p) => {
  acc[p.group] = (acc[p.group] ?? 0) + 1;
  return acc;
}, {});

const matchesPlayed = (playerId: string): number =>
  tournament.completedMatches.filter(m =>
    m.player1.toLowerCase() === playerId.toLowerCase() ||
    m.player2.toLowerCase() === playerId.toLowerCase()
  ).length;
---

<Layout title="Gracze — Pierwsza Liga Cebularzowa 2026" currentPage="gracze">
  <table>
    <thead>
      <tr>
        <th>#</th>
        <th></th>
        <th>Gracz</th>
        <th>Chess.com</th>
        <th>Postęp</th>
        <th>Ranking</th>
      </tr>
    </thead>
    <tbody>
      {players.map(p => {
        const played = matchesPlayed(p.id);
        const total = groupSizes[p.group] - 1;
        const pct = total > 0 ? (played / total) * 100 : 0;
        return (
          <tr>
            <td class="no">{p.no}</td>
            <td class="avatar">
              {p.picture
                ? <img src={p.picture} alt={p.id} width="32" height="32" />
                : <span class="avatar-placeholder" />}
            </td>
            <td><a href={`/players/${p.id}`}>{shorten(p.displayName)}</a></td>
            <td class="muted">
              {p.id}
              <a href={p.url} target="_blank" rel="noopener noreferrer" title={`${p.id} on Chess.com`} class="ext-link">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
                  <polyline points="15 3 21 3 21 9"></polyline>
                  <line x1="10" y1="14" x2="21" y2="3"></line>
                </svg>
              </a>
            </td>
            <td class="progress-cell">
              <span class="progress-label">{played}/{total}</span>
              <div class="progress-bar-track">
                <div class="progress-bar-fill" style={`width: ${pct}%`}></div>
              </div>
            </td>
            <td class="ranking">{p.ranking}</td>
          </tr>
        );
      })}
    </tbody>
  </table>
</Layout>

<style>
  table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
  }

  th {
    text-align: left;
    color: #8b949e;
    font-weight: 600;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.4rem 0.75rem;
    border-bottom: 1px solid #21262d;
  }

  td {
    padding: 0.55rem 0.75rem;
    border-bottom: 1px solid #161b22;
    vertical-align: middle;
  }

  tr:last-child td {
    border-bottom: none;
  }

  td.no {
    color: #484f58;
    width: 2rem;
    text-align: right;
  }

  td.avatar {
    width: 40px;
    padding-left: 0.5rem;
    padding-right: 0.5rem;
  }

  td.avatar img {
    display: block;
    border-radius: 50%;
  }

  .avatar-placeholder {
    display: block;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: #21262d;
  }

  td a {
    color: #58a6ff;
    text-decoration: none;
  }

  td a:hover {
    text-decoration: underline;
  }

  td.muted {
    color: #8b949e;
    font-size: 0.82rem;
    white-space: nowrap;
  }

  .ext-link {
    color: #484f58;
    margin-left: 0.25rem;
    vertical-align: middle;
    display: inline-flex;
    align-items: center;
    text-decoration: none !important;
  }

  .ext-link:hover {
    color: #8b949e;
  }

  td.progress-cell {
    min-width: 90px;
  }

  .progress-label {
    display: block;
    font-size: 0.75rem;
    color: #8b949e;
    margin-bottom: 3px;
  }

  .progress-bar-track {
    height: 3px;
    background: #21262d;
    border-radius: 2px;
    overflow: hidden;
  }

  .progress-bar-fill {
    height: 100%;
    background: #3fb950;
    border-radius: 2px;
    transition: width 0.3s ease;
  }

  td.ranking {
    color: #e6edf3;
    font-weight: 600;
    text-align: right;
  }

  th:last-child {
    text-align: right;
  }
</style>
