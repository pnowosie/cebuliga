---
import Layout from '../layouts/Layout.astro';
import GroupProgress from '../components/GroupProgress.astro';
import tournament from '../../data/tournament.json';
import players from '../../data/players.json';

const playersInGroup = (g: string) => players.filter(p => p.group === g).length;
const totalGames = (g: string) => {
  const n = playersInGroup(g);
  return n * (n - 1); // n*(n-1)/2 matches × 2 games each
};

const gamesPlayed = (g: string) =>
  tournament.completedMatches
    .filter(m => m.group === g)
    .reduce((sum, m) => sum + m.games.length, 0);
---

<Layout title="Pierwsza Liga Cebularzowa 2026" currentPage="home">
  <h2>Home</h2>
  <div class="groups">
    <GroupProgress label="Grupa 🅰️" completedGames={gamesPlayed('A')} totalGames={totalGames('A')} />
    <GroupProgress label="Grupa 🅱️" completedGames={gamesPlayed('B')} totalGames={totalGames('B')} />
  </div>
</Layout>

<style>
  .groups {
    display: flex;
    gap: 1.5rem;
  }

  @media (max-width: 480px) {
    .groups {
      flex-direction: column;
    }
  }
</style>
